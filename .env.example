# LLM API Keys (choose one - both are FREE)
GROQ_API_KEY=your-groq-key          # Free: https://console.groq.com/keys
GEMINI_API_KEY=your-gemini-key       # Free: https://aistudio.google.com/apikey

# Weather API (free)
WEATHER_API_KEY=your-weatherapi-key   # Free: https://www.weatherapi.com

# Optional
OPENAI_API_KEY=your-openai-key       # Paid: https://platform.openai.com
